# Copia este archivo como .env y completa los valores reales.
# .env NUNCA debe subirse a git (ya está en .gitignore).

# Django
DJANGO_SECRET_KEY=cambia-esto-por-una-clave-secreta-larga-y-aleatoria
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=

# Base de datos MySQL
# En desarrollo local (sin Docker) usa DB_HOST=localhost.
# En despliegue con docker-compose usa DB_HOST=db (nombre del servicio) y
# define además DB_ROOT_PASSWORD (solo la usa el contenedor de MySQL).
DB_NAME=lectosoft
DB_USER=lectosoft_user
DB_PASSWORD=cambia-esta-clave
DB_HOST=localhost
DB_PORT=3306
DB_ROOT_PASSWORD=cambia-esta-clave-root

# Correo (Gmail)
EMAIL_HOST_USER=lectosoft2026@gmail.com
EMAIL_HOST_PASSWORD=
